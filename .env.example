# ============================================================
# Car Dealership Backend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it is in .gitignore.
# ============================================================

# PostgreSQL connection URL (from Neon dashboard)
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_URL=jdbc:postgresql://your-neon-host.neon.tech/your-db?sslmode=require

# Database credentials (from Neon dashboard)
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# JWT secret — any long random string (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# JWT expiration in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION=86400000

# CORS — your frontend URL (React dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173
