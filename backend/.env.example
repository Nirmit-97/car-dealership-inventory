# ============================================================
# Car Dealership Backend — Environment Variables
# ============================================================

# PostgreSQL connection URL (e.g. from Neon dashboard)
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_URL=jdbc:postgresql://your-neon-host.neon.tech/neondb?sslmode=require

# Database credentials (if not embedded in connection url)
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# JWT secret — must be a long cryptographically secure string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Dynamic port binding for Railway/Render hosting environment
PORT=8080

# CORS — permitted frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173
